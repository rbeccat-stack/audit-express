[Unit]
Description=Audit Growth Express — Backend FastAPI
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/audit-express/backend
EnvironmentFile=/root/.hermes/.env
ExecStart=/opt/audit-express/backend/.venv/bin/uvicorn app:app --host 0.0.0.0 --port 8000
Environment=PORT=8000

Restart=always
RestartSec=5
TimeoutStopSec=30

StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target