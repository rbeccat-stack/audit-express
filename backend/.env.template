# Audit Growth Express — Backend Configuration
# Copie ce fichier en .env et remplis les valeurs

# OBLIGATOIRE : Ta clé API OpenRouter (la même qu'utilise Hermes)
# Ouvre https://openrouter.ai/keys → copie ta clé ici
OPENROUTER_API_KEY=sk-or-xxx

# Optionnel : modèle LLM à utiliser (défaut : openai/gpt-4o-mini)
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Optionnel : port du serveur (défaut : 8000)
# PORT=8000