# Audit Growth Express — Caddy reverse proxy
# Domaine à remplacer par le tien

# Exemple avec ton domaine :
# audit.ton-domaine.fr {
#     # Frontend (index.html)
#     root * /opt/audit-express
#     try_files {path} /index.html
#
#     # Backend API
#     handle_path /api/* {
#         reverse_proxy localhost:8000
#     }
#
#     file_server
# }

# === Variante sans domaine (IP directe, port 80) ===
# :80 {
#     root * /opt/audit-express
#     try_files {path} /index.html
#     handle_path /api/* {
#         reverse_proxy localhost:8000
#     }
#     file_server
# }